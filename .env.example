# =============================================================
# Homeo Trust — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local. Do not put real secrets in this file.
#
# WINDOWS SELF-HOST: do NOT edit this by hand for the LOCAL database mode.
# `setup.bat` generates the real root `.env` from this template on first run.
#
#   Option A — LOCAL database (full package): setup fills a freshly generated
#     AUTH_SECRET and a random local DB password (never committed, never shipped),
#     wires DATABASE_URL/DIRECT_URL to the bundled local PostgreSQL
#     (127.0.0.1:5433), and stamps HT_DB_MODE=local. Leave the URLs below as-is.
#
#   Option B — REMOTE database (lite package, or full pointed at e.g. Neon): you
#     EDIT DATABASE_URL (provider POOLED conn) and DIRECT_URL (provider DIRECT/
#     non-pooled conn) here — both ending in ?sslmode=require for Neon — then run
#     setup.bat. It keeps your two URLs, fills the missing AUTH_SECRET + admin
#     temp password, and stamps HT_DB_MODE=remote. (HT_DB_MODE is written by
#     setup; you do not need to add it yourself.)
#
# In BOTH modes setup sets STORAGE_LOCAL_DIR to an absolute path under
# data\attachments (attachments always stay local) and pins the app to
# http://127.0.0.1:8787. The values below are DEV PLACEHOLDERS only — no real
# secrets, hosts, or passwords.
# =============================================================

# --- Database (required) ---
# PostgreSQL. Development uses LOCAL PostgreSQL (e.g. running in WSL).
# Any PostgreSQL host works in production; no specific provider is required.
#   DATABASE_URL — connection the app uses at runtime (pooled in production).
#   DIRECT_URL   — direct (non-pooled) connection used by Prisma migrations and
#                  seeding. In development this is the SAME local database.
# Single low-resource instance: cap the pool by adding `?connection_limit=5`
# (or lower) to DATABASE_URL so Prisma does not open a large pool on a laptop.
DATABASE_URL="postgresql://homeo_user:homeo_dev_password@localhost:5432/homeo_trust_dev"
DIRECT_URL="postgresql://homeo_user:homeo_dev_password@localhost:5432/homeo_trust_dev"

# --- Auth (required) ---
# Used to HMAC session tokens. Must be at least 32 characters.
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-secure-random-secret-at-least-32-chars"

# --- App ---
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Opt out of Next.js anonymous telemetry (no network calls at build/run time).
NEXT_TELEMETRY_DISABLED="1"

# --- First admin bootstrap (used by `pnpm db:seed` only) ---
# The first admin is created with mustChangePassword = true and must set a new
# password on first login. Read by prisma/seed.ts, not at app runtime.
FIRST_ADMIN_NAME="Site Admin"
FIRST_ADMIN_EMAIL="admin@example.com"
FIRST_ADMIN_USERNAME="admin"
FIRST_ADMIN_TEMP_PASSWORD="change-this-temporary-admin-pass"

# (No email/SMTP: user creation shows the temporary password once on screen for
# the admin to hand over. There is no mail path.)

# --- Attachment storage (Phase 7) ---
# STORAGE_DRIVER selects the backend: "local" (default) or "s3".
#   local — writes blobs to STORAGE_LOCAL_DIR (a gitignored, NON-public dir).
#           Files are served only via the authenticated download route.
#   s3    — design stub only; not wired to a bucket yet (see src/lib/storage/s3.ts).
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="var/attachments"

# S3-compatible object store (only when STORAGE_DRIVER=s3). The bucket MUST be
# private (no public ACL/policy); only short-lived presigned URLs are handed out.
# STORAGE_S3_BUCKET=""
# STORAGE_S3_REGION=""
# STORAGE_S3_ENDPOINT=""              # optional, for non-AWS (MinIO/R2/…)
# STORAGE_S3_ACCESS_KEY_ID=""
# STORAGE_S3_SECRET_ACCESS_KEY=""
# STORAGE_S3_FORCE_PATH_STYLE="false" # optional, true for MinIO-style endpoints
